{
  "name": "NekoMusic",
  "version": "2026.307.9",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "Neko云音乐。完全免费的音乐平台！",
  "author": "Fantasy Network「梦幻网络」<support@cnmsb.xin>",
  "homepage": "https://music.cnmsb.xin",
  "scripts": {
    "dev": "npm run electron:dev",
    "build": "vite build && cp electron/preload.cjs dist-electron/preload.cjs && electron-builder",
    "build:dir": "vite build && cp electron/preload.cjs dist-electron/preload.cjs && electron-builder --dir",
    "build:win": "vite build && cp electron/preload.cjs dist-electron/preload.cjs && electron-builder --win",
    "build:mac": "vite build && cp electron/preload.cjs dist-electron/preload.cjs && electron-builder --mac",
    "build:linux": "vite build && cp electron/preload.cjs dist-electron/preload.cjs && electron-builder --linux",
    "build:all": "vite build && cp electron/preload.cjs dist-electron/preload.cjs && electron-builder -wl",
    "postinstall": "echo '=== Linux系统依赖提示 ===' && echo '如果在Linux下托盘图标或右键菜单不工作，请运行：' && echo 'sudo apt-get install libayatana-appindicator3-1 libappindicator3-1' && echo '========================'",
    "preview": "vite preview",
    "electron:dev": "vite && electron ."
  },
  "dependencies": {
    "vue": "^3.5.27",
    "vue-router": "^5.0.1"
  },
  "devDependencies": {
    "terser": "^5.31.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "electron": "37.1.0",
    "electron-builder": "^26.4.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-vue-devtools": "^8.0.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "build": {
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/",
      "strictSSL": true,
      "version": "37.1.0"
    },
    "appId": "com.neko.music",
    "productName": "Neko云音乐",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "public/icon.png",
      "public/tray-*.png",
      "!node_modules",
      "!electron",
      "!dist/win-unpacked",
      "!dist/mac",
      "!dist/mac-arm64",
      "!dist/linux",
      "!dist-linux-unpacked",
      "!dist/mac-universal",
      "!**/*.{exe,msi,zip,7z,dmg,AppImage}",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.vue",
      "!vite.config.js",
      "!jsconfig.json",
      "!LICENSE",
      "!README.md",
      "!**/*.md",
      "!src/**/*",
      "!test/**/*",
      "!tests/**/*",
      "!coverage/**/*",
      "!.git/**/*",
      "!.github/**/*",
      "!**/test/**/*",
      "!**/tests/**/*",
      "!**/*.test.*",
      "!**/*.spec.*",
      "!**/.git*",
      "!**/.DS_Store",
      "!**/Thumbs.db",
      "!**/.idea/**/*",
      "!**/.vscode/**/*",
      "!**/node_modules/**/*",
      "!**/dist-electron/**/node_modules/**/*",
      "!**/.nyc_output/**/*",
      "!**/*.log",
      "!**/*.tmp",
      "!**/.cache/**/*",
      "!**/.temp/**/*",
      "!**/coverage/**/*",
      "!**/release/**/*",
      "!**/build/**/*",
      "!**/.env*",
      "!**/.eslint*",
      "!**/.prettier*",
      "!**/tsconfig.json",
      "!**/.editorconfig",
      "!**/yarn.lock",
      "!**/pnpm-lock.yaml",
      "!**/bun.lockb",
      "!**/package-lock.json"
    ],
    "asar": true,
    "asarUnpack": [],
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "npmRebuild": false,
    "electronVersion": "37.1.0",
    "fileAssociations": [],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${os}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.music",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "Audio",
      "description": "Neko云音乐 - 一款简洁优雅的音乐播放器",
      "maintainer": "Fantasy Network <support@cnmsb.xin>",
      "synopsis": "Neko云音乐 - 简洁优雅的音乐播放器",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "perMachine": false,
      "allowElevation": false,
      "deleteAppDataOnUninstall": false,
      "license": null,
      "differentialPackage": false,
      "artifactName": "${productName}-${version}-${os}.${ext}",
      "displayLanguageSelector": false,
      "guid": "com.neko.music",
      "packElevateHelper": false,
      "runAfterFinish": true
    },
    "publish": null,
    "afterPack": "./scripts/afterPack.cjs"
  }
}